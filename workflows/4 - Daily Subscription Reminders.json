    {
      "parameters": {
        "jsCode": "const rows = $('Get Active Tracker Rows').all().map(i => i.json);\nconst today = new Date(); today.setHours(0,0,0,0);\nconst twoDaysOut = new Date(today); twoDaysOut.setDate(today.getDate() + 2);\nconst fmt = d => d.toISOString().slice(0,10);\n\nconst due = [];\nfor (const r of rows) {\n  if (!r.event_date) continue;\n  if (r.event_date === fmt(twoDaysOut) && r.reminder_2day_sent !== true && r.reminder_2day_sent !== 'true') {\n    due.push({ ...r, reminder_type: '2day' });\n  }\n  if (r.event_date === fmt(today) && r.reminder_dayof_sent !== true && r.reminder_dayof_sent !== 'true') {\n    due.push({ ...r, reminder_type: 'dayof' });\n  }\n}\nreturn due.map(d => ({ json: d }));"
      },
