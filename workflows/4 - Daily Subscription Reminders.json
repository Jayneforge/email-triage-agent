{
  "name": "4 - Daily Subscription Reminders",
  "nodes": [
    {
      "parameters": {
        "content": "## Daily Subscription Reminders\n\nRuns every morning at 6am. This is the piece that makes the tracker independent of whether the company actually sends a reminder — it checks dates you already recorded, not incoming mail.\n\nAlso doubles as the Monday weekly-schedule sender: on Mondays it additionally pulls the full week's upcoming events and sends a summary.",
        "height": 300,
        "width": 380
      },
      "id": "54b293b5-4325-4174-b84a-ad1485374d13",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 6 * * *"
            }
          ]
        }
      },
      "id": "b12c02a5-554b-4f3c-b8f3-04499126d2bf",
