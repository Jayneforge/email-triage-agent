      "id": "e188983e-5a1a-40bb-88db-a2995a88a80d",
      "name": "Get This Week's Events",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1024,
        400
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "sz5NKilchrJgzsru",
          "name": "Google Sheets account"
        }
      }
