    {
      "parameters": {
        "jsCode": "const mentions = $('Get Promo Mentions').all().map(i => i.json).filter(m => m && m.sender_email);\nconst decided = new Set($('Get Sender Preferences').all().map(i => i.json).filter(p => p && p.sender_email).map(p => p.sender_email));\n\n// only count this week (Mon 00:00 -> now)\nconst now = new Date();\nconst day = now.getDay() || 7;\nconst monday = new Date(now); monday.setDate(now.getDate() - day + 1); monday.setHours(0,0,0,0);\n\nconst thisWeek = mentions.filter(m => new Date(m.received_at) >= monday && !decided.has(m.sender_email));\n\nconst bySender = {};\nfor (const m of thisWeek) {\n  if (!bySender[m.sender_email]) {\n    bySender[m.sender_email] = {\n      uuid: Math.random().toString(36).slice(2) + Date.now().toString(36),\n      sender_email: m.sender_email, sender_domain: m.sender_domain,\n      first_seen_this_week: m.received_at, last_subject: m.subject, count_this_week: 0,\n      unsubscribe_method: m.unsubscribe_method, unsubscribe_target: m.unsubscribe_target,\n      decision: 'pending'\n    };\n  }\n  bySender[m.sender_email].count_this_week += 1;\n  bySender[m.sender_email].last_subject = m.subject;\n}\nreturn Object.values(bySender).map(v => ({ json: v }));"
      },
