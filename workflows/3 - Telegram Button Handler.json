    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\nconst cb = $('Parse Callback Data').first().json;\nreturn [{ json: { ...row, action: cb.action, callback_query_id: cb.callback_query_id, chat_id: cb.chat_id, message_id: cb.message_id } }];"
      },
