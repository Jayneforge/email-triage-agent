{
  "name": "3 - Telegram Button Handler",
  "nodes": [
    {
      "parameters": {
        "content": "## Telegram Button Handler\n\nSeparate trigger from the digest sender — this one listens for button taps (callback_query), not chat messages.\n\nOn Unsubscribe: hits the link (HTTP GET) or auto-sends the mailto unsubscribe request via Gmail, per your call.\nEither way: writes the decision to Sender Preferences permanently (never asked again) and edits the original Telegram message so it doesn't sit there stale.",
        "height": 300,
        "width": 380
      },
      "id": "89a1e51e-baf7-477a-86f4-86ac91edd79e",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -2656,
        -96
      ]
    },
    {
      "parameters": {
        "updates": [
          "callback_query"
        ],
        "additionalFields": {}
      },
      "id": "e6017b3c-de98-4a0d-adf7-55c7c8abd635",
      "name": "Button Tapped",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        -2160,
        112
      ],
      "webhookId": "aa053339-c7f9-4668-a8ed-4b3235e2c434",
      "credentials": {
        "telegramApi": {
          "id": "e1hHtBEfIWBasJb9",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const cb = $json.callback_query;\nconst [action, uuid] = cb.data.split('|');\nreturn [{ json: {\n  action, uuid,\n  callback_query_id: cb.id,\n  chat_id: cb.message.chat.id,\n  message_id: cb.message.message_id\n} }];"
      },
      "id": "8d7be10d-323d-462c-8a9f-42ae2871c695",
      "name": "Parse Callback Data",
      "type": "n8n-nodes-base.code",
