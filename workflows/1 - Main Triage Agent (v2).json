        "jsCode": "const labelMap = {\n  'Urgent': 'Label_4032412265699218502', 'Newsletter': 'Label_7234085200392634367', 'Receipt': 'Label_2101271369811818868',\n  'Task': 'Label_558085458143635233', 'Personal': 'Label_4235438555674045296', 'Spam-like': 'Label_1679977285354885820'\n};\nconst item = $input.first().json;\nreturn [{ json: {\n  ...item,\n  category_label_id: labelMap[item.category] || labelMap['Personal'],\n  needs_action_label_id: 'Label_7865694268348548798',\n  safe_to_archive: ['Newsletter','Receipt','Spam-like'].includes(item.category) && !item.action_required\n} }];"
