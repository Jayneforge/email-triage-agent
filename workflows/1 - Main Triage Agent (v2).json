        "jsCode": "// Entity already tracked. Only touch reminder flags if the date actually changed.\nconst incoming = $('Parse Classification').first().json;\nconst existing = $input.first().json;\nconst dateChanged = existing.event_date !== incoming.event_date;\nreturn [{ json: {\n  row_number: existing.row_number,\n  entity_id: existing.entity_id,\n  event_date: dateChanged ? incoming.event_date : existing.event_date,\n  reminder_2day_sent: dateChanged ? false : existing.reminder_2day_sent,\n  reminder_dayof_sent: dateChanged ? false : existing.reminder_dayof_sent,\n  confirmed_by_company_reminder: incoming.is_reminder_email ? true : existing.confirmed_by_company_reminder,\n  calendar_event_id: existing.calendar_event_id,\n  date_changed: dateChanged\n} }];"
