      "parameters": {
        "jsCode": "const header = $('Parse Classification').first().json.list_unsubscribe_header || '';\nconst httpMatch = header.match(/<(https?:[^>]+)>/);\nconst mailtoMatch = header.match(/<mailto:([^>]+)>/);\nconst item = $('Parse Classification').first().json;\nreturn [{ json: {\n  sender_email: item.sender_email,\n  sender_domain: (item.sender_email.split('@')[1] || ''),\n  subject: item.subject,\n  unsubscribe_method: httpMatch ? 'link' : (mailtoMatch ? 'mailto' : 'none_found'),\n  unsubscribe_target: httpMatch ? httpMatch[1] : (mailtoMatch ? mailtoMatch[1] : ''),\n  received_at: item.received_at\n} }];"
      },
