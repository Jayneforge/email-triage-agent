    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization ",
              "value": "[[PLACE YOUR API KEY HERE]]"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"openai/gpt-oss-120b\",\n  reasoning_effort: \"medium\",\n  messages: [\n    { role: \"system\", content: \"You are an email triage assistant. Judge category and action_required independently. Category reflects what kind of email this is; action_required reflects whether a reasonable recipient needs to do something, regardless of category. An email can be Spam-like or suspicious AND still have action_required=true, because a demand for a reply or personal info is itself something the recipient needs to consciously act on (even if that action is 'do not comply'). Do not set action_required=false just because something looks like spam or phishing. Respond with ONLY valid JSON, no preamble, no markdown fences, matching exactly: {\\\"category\\\": one of [\\\"Urgent\\\",\\\"Newsletter\\\",\\\"Receipt\\\",\\\"Task\\\",\\\"Personal\\\",\\\"Spam-like\\\"], \\\"priority\\\": one of [\\\"High\\\",\\\"Medium\\\",\\\"Low\\\"], \\\"action_required\\\": boolean, \\\"action_summary\\\": string, \\\"unsubscribe_candidate\\\": boolean, \\\"is_subscription_or_appointment\\\": boolean, \\\"event_type\\\": one of [\\\"subscription_renewal\\\",\\\"subscription_expiration\\\",\\\"appointment\\\",\\\"none\\\"], \\\"event_date\\\": string (YYYY-MM-DD, empty if none/cannot determine), \\\"entity_name\\\": string (e.g. Netflix, Dr. Adaeze - Dental Checkup, empty if none), \\\"is_reminder_email\\\": boolean (true if this email IS a reminder about an already-existing subscription/appointment, false if it's the original confirmation revealing a future date)}\" },\n    { role: \"user\", content: \"From: \" + $('Normalize Fields').first().json.from + \"\\nSubject: \" + $('Normalize Fields').first().json.subject + \"\\nSnippet: \" + $('Normalize Fields').first().json.snippet + \"\\nToday's date: \" + $now.toISODate() }\n  ]\n}) }}",
        "options": {}
      },
